# URL бэкенда. Локально: http://localhost:3001 (если бэкенд на порту 3001).
# На сервере: https://your-backend.vercel.app или другой хост API.
# Пусто = запросы на тот же домен (same origin).
VITE_API_URL=http://localhost:3001

# Полный URL сайта для превью в Telegram/соцсетях (og:image и т.д.). Без слеша в конце.
# Продакшен: https://ozone-coin.online или https://www.ozone-coin.online
VITE_SITE_URL=https://ozone-coin.online
